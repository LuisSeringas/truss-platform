# PostgreSQL connection string (Supabase: Settings > Database > Connection string)
# Use the "Transaction" connection string (port 6543) for serverless; "Session" (5432) for local dev
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# Auth.js secret — generate with: openssl rand -base64 32
AUTH_SECRET=your-secret-here

# Production URL — used by NextAuth for callbacks and CSRF
# Vercel sets this automatically via VERCEL_URL; only needed for non-Vercel deploys
# NEXTAUTH_URL=https://your-domain.com

# Supabase Storage (Settings > API)
# URL is the project URL, e.g. https://[project-ref].supabase.co
SUPABASE_URL=https://[project-ref].supabase.co
# Service role key (secret — never expose to browser)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
